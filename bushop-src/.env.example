# FastAPI scraper service URL (server-side only, never exposed to browser)
SCRAPER_API_URL=http://localhost:8000

# API Key for Next.js → FastAPI authentication (E0-S6)
INTERNAL_API_KEY=your-api-key-here

# Next.js public URL (for sitemap generation in E6)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
